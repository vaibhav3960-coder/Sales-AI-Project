generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model EventType {
  id             String    @id @default(uuid())
  name           String
  duration       Int       // in minutes
  slug           String    @unique
  description    String?
  bufferTime     Int       @default(0) // in minutes
  customQuestion String?   // optional question for invitee
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  meetings       Meeting[]
}

model Availability {
  id        String   @id @default(uuid())
  dayOfWeek Int      // 0 = Sunday, 1 = Monday, etc.
  startTime String   // e.g. "09:00"
  endTime   String   // e.g. "17:00"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([dayOfWeek, startTime, endTime])
}

model Meeting {
  id           String    @id @default(uuid())
  eventTypeId  String
  eventType    EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  inviteeName  String
  inviteeEmail String
  customAnswer String?   // invitee's answer to the custom question
  startTime    DateTime
  endTime      DateTime
  status       String    @default("booked") // "booked" or "canceled"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
